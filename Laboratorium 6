#include <iostream>
#include <string>
#include <vector>
#include <fstream>
using namespace std;
struct WpisObecnosci {
    string nazwa_listy;
    bool czy_obecny;
};
class Przedstawialny {
public:
    virtual string przedstawSie() const = 0;
    virtual ~Przedstawialny() {}
};
class Serializable {
public:
    virtual void serializuj(ostream& out) const = 0;
    virtual ~Serializable() {}
};
class Drukarka {
public:
    static void drukuj(const Przedstawialny& obj) {
        cout << obj.przedstawSie() << endl;
    }
};
class Osoba : public Przedstawialny, public Serializable {
protected:
    int indeks;
    string imie;
    string nazwisko;
    string data_urodzenia;
    float wzrost;
    vector<WpisObecnosci> listy;
    string formatujListy() const {
        string wynik;
        if (listy.empty()) {
            wynik += "  Brak przypisanych list obecnosci.\n";
        } else {
            for (const auto& l : listy) {
                wynik += "  Lista [" + l.nazwa_listy + "]: ";
                wynik += (l.czy_obecny ? "Obecny" : "Nieobecny");
                wynik += "\n";
            }
        }
        return wynik;
    }
public:
    Osoba(int startowy_indeks = 0, string startowe_imie = "", string startowe_nazwisko = "", string data_ur = "Brak", float wzr = 0.0f) {
        indeks = startowy_indeks;
        imie = startowe_imie;
        nazwisko = startowe_nazwisko;
        data_urodzenia = data_ur;
        wzrost = wzr;
    }
    virtual ~Osoba() {}
    virtual void ustaw() {
        cout << "Indeks: "; cin >> indeks;
        cout << "Imie: "; cin >> imie;
        cout << "Nazwisko: "; cin >> nazwisko;
        cout << "Data urodzenia: "; cin >> data_urodzenia;
        cout << "Wzrost: "; cin >> wzrost;
    }
    virtual void edytuj() {
        cout << "Nowy indeks: "; cin >> indeks;
        cout << "Nowe imie: "; cin >> imie;
        cout << "Nowe nazwisko: "; cin >> nazwisko;
        cout << "Nowa data urodzenia: "; cin >> data_urodzenia;
        cout << "Nowy wzrost: "; cin >> wzrost;
    }
    void ustaw_indeks(int wartosc) { indeks = wartosc; }
    void ustaw_imie(string wartosc) { imie = wartosc; }
    void ustaw_nazwisko(string wartosc) { nazwisko = wartosc; }
    int pobierz_indeks() { return indeks; }
    string pobierz_imie() { return imie; }
    string pobierz_nazwisko() { return nazwisko; }
    void dodaj_do_listy(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return;
        }
        listy.push_back({nazwa_listy, false});
    }
    void ustaw_obecnosc(string nazwa_listy, bool obecnosc) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) {
                l.czy_obecny = obecnosc;
                return;
            }
        }
    }
    bool czy_jest_na_liscie(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return true;
        }
        return false;
    }
    bool pobierz_obecnosc(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return l.czy_obecny;
        }
        return false;
    }
    string przedstawSie() const override {
        string s = "[" + getTyp() + "] " + to_string(indeks) + " - " + imie + " " + nazwisko + "\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }
    virtual void wyswietl_info() { 
        Drukarka::drukuj(*this);
    }
    virtual string getTyp() const { return "OSOBA"; }
    void serializuj(ostream& out) const override {
        out << "[" << getTyp() << "]\n";
        out << "Indeks: " << indeks << "\n";
        out << "Imie: " << imie << "\n";
        out << "Nazwisko: " << nazwisko << "\n";
        out << "DataUrodzenia: " << data_urodzenia << "\n";
        out << "Wzrost: " << wzrost << "\n";
        if (listy.empty()) {
            out << "Listy: brak\n";
        } else {
            for (const auto& l : listy) {
                out << "Lista: " << l.nazwa_listy << " = " << (l.czy_obecny ? "Obecny" : "Nieobecny") << "\n";
            }
        }
    }
};
class Student : public Osoba {
protected:
    string kierunek;
    int semestr;
public:
    Student(int inx = 0, string im = "", string naz = "", string kier = "", int sem = 0, string data_ur = "Brak", float wzr = 0.0f) 
        : Osoba(inx, im, naz, data_ur, wzr), kierunek(kier), semestr(sem) {}
    void ustaw() override {
        Osoba::ustaw();
        cout << "Kierunek: "; cin >> kierunek;
        cout << "Semestr: "; cin >> semestr;
    }
    void edytuj() override {
        Osoba::edytuj();
        cout << "Nowy kierunek: "; cin >> kierunek;
        cout << "Nowy semestr: "; cin >> semestr;
    }
    void setKierunek(string nowy_kierunek) { kierunek = nowy_kierunek; }
    void setSemestr(int nowy_sem) { semestr = nowy_sem; }
    string getTyp() const override { return "STUDENT"; }
    string przedstawSie() const override {
        string s = "[" + getTyp() + "] " + to_string(indeks) + " - " + imie + " " + nazwisko + " (" + kierunek + ", semestr: " + to_string(semestr) + ")\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }
    void serializuj(ostream& out) const override {
        Osoba::serializuj(out);
        out << "Kierunek: " << kierunek << "\n";
        out << "Semestr: " << semestr << "\n";
    }
};
class StudentZaoczny : public Student {
public:
    StudentZaoczny(int inx = 0, string im = "", string naz = "", string kier = "", int sem = 0, string data_ur = "Brak", float wzr = 0.0f) 
        : Student(inx, im, naz, kier, sem, data_ur, wzr) {}
    string getTyp() const override { return "STUDENT ZAOCZNY"; }
    string przedstawSie() const override {
        string s = "[" + getTyp() + "] " + to_string(indeks) + " - " + imie + " " + nazwisko + " (" + kierunek + ", semestr: " + to_string(semestr) + ")\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }
};
class Prowadzacy : public Osoba {
protected:
    string tytul_naukowy;
    string przedmiot;
public:
    Prowadzacy(int inx = 0, string im = "", string naz = "", string tytul = "", string przedm = "", string data_ur = "Brak", float wzr = 0.0f)
        : Osoba(inx, im, naz, data_ur, wzr), tytul_naukowy(tytul), przedmiot(przedm) {}
    void ustaw() override {
        Osoba::ustaw();
        cout << "Tytul naukowy: "; cin >> tytul_naukowy;
        cout << "Przedmiot: "; cin >> przedmiot;
    }
    void edytuj() override {
        Osoba::edytuj();
        cout << "Nowy tytul naukowy: "; cin >> tytul_naukowy;
        cout << "Nowy przedmiot: "; cin >> przedmiot;
    }
    void setTytul(string nowy_tytul) { tytul_naukowy = nowy_tytul; }
    void setPrzedmiot(string nowy_przedmiot) { przedmiot = nowy_przedmiot; }
    string getTyp() const override { return "PROWADZACY"; }
    string przedstawSie() const override {
        string s = "[" + getTyp() + "] ID: " + to_string(indeks) + " - " + tytul_naukowy + " " + imie + " " + nazwisko + " (Przedmiot: " + przedmiot + ")\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }
    void serializuj(ostream& out) const override {
        Osoba::serializuj(out);
        out << "Tytul naukowy: " << tytul_naukowy << "\n";
        out << "Przedmiot: " << przedmiot << "\n";
    }
};
class listaObecnosci {
private:
    vector<Osoba*> baza_osob;
    int szukaj_osoby(string szukane_nazwisko) {
        for (int i = 0; i < (int)baza_osob.size(); i++) {
            if (baza_osob[i]->pobierz_nazwisko() == szukane_nazwisko) {
                return i;
            }
        }
        return -1;
    }
public:
    listaObecnosci() {}
    ~listaObecnosci() {
        for (auto o : baza_osob) {
            delete o;
        }
    }
    void dodaj_osobe(Osoba* nowa_osoba) {
        baza_osob.push_back(nowa_osoba);
    }
    void edytuj_osobe(string tekst_do_edycji) {
        int i = szukaj_osoby(tekst_do_edycji);
        if (i != -1) {
            baza_osob[i]->edytuj();
            cout << "Dane zaktualizowane!" << endl;
        } else {
            cout << "Nie znaleziono takiego nazwiska!" << endl;
        }
    }
    void usun_osobe(string tekst_do_edycji) {
        int pozycja = szukaj_osoby(tekst_do_edycji);
        if (pozycja != -1) {
            delete baza_osob[pozycja];
            baza_osob.erase(baza_osob.begin() + pozycja);
            cout << "Osoba usunieta." << endl;
        } else {
            cout << "Nie ma kogo usunac, brak nazwiska w bazie." << endl;
        }
    }
    void dodaj_do_listy(string nazwa_listy, string nazwisko_osoby) {
        int i = szukaj_osoby(nazwisko_osoby);
        if (i != -1) {
            baza_osob[i]->dodaj_do_listy(nazwa_listy);
            cout << "Dodano do listy " << nazwa_listy << "." << endl;
        } else {
            cout << "Nie znaleziono osoby w bazie." << endl;
        }
    }
    void ustaw_obecnosc(string nazwa_listy, string nazwisko_osoby, bool czy_obecny) {
        int i = szukaj_osoby(nazwisko_osoby);
        if (i != -1) {
            if (baza_osob[i]->czy_jest_na_liscie(nazwa_listy)) {
                baza_osob[i]->ustaw_obecnosc(nazwa_listy, czy_obecny);
            } else {
                cout << "Osoby nie ma na tej liscie." << endl;
            }
        } else {
            cout << "Nie znaleziono osoby w bazie." << endl;
        }
    }
    void wyswietl(string nazwa_listy) {
        cout << "\nOsoby na liscie: " << nazwa_listy << endl;
        cout << "--------------------------------------" << endl;
        bool ktos_jest = false;
        for (auto o : baza_osob) {
            if (o->czy_jest_na_liscie(nazwa_listy)) {
                ktos_jest = true;
                o->wyswietl_info();
            }
        }
        if (!ktos_jest) {
            cout << "Brak osob na tej liscie." << endl;
        }
    }
    void zapisz_do_pliku(int tryb, const string& nazwa_pliku, const string& szukane_nazwisko = "") {
        if (baza_osob.empty()) {
            cout << "Baza jest pusta, brak danych do zapisu.\n";
            return;
        }
        ofstream out(nazwa_pliku);
        if (!out) {
            cout << "Nie mozna otworzyc/utworzyc pliku!\n";
            return;
        }
        if (tryb == 1) {
            for (auto o : baza_osob) {
                o->serializuj(out);
                out << "------------------------\n";
            }
            cout << "Zapisano " << baza_osob.size() << " osob do pliku: " << nazwa_pliku << "\n";
        } else if (tryb == 2) {
            int i = szukaj_osoby(szukane_nazwisko);
            if (i != -1) {
                baza_osob[i]->serializuj(out);
                cout << "Zapisano dane osoby " << szukane_nazwisko << " do pliku: " << nazwa_pliku << "\n";
            } else {
                cout << "Nie znaleziono osoby o nazwisku: " << szukane_nazwisko << "\n";
            }
        } else {
            cout << "Nieprawidlowy tryb zapisu.\n";
        }
        out.close();
    }
};
int main() {
    listaObecnosci system_obecnosci;
