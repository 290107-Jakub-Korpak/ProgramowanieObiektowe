#include <iostream>
#include <string>
#include <vector>
#include <fstream>
#include <map>

using namespace std;

struct WpisObecnosci {
    string nazwa_listy;
    bool czy_obecny;
};

class Przedstawialny {
public:
    virtual string przedstawSie() const = 0;
    virtual ~Przedstawialny() {}
};

class IEksportowalny {
public:
    virtual map<string, string> eksportuj() const = 0;
    virtual vector<map<string, string>> eksportujListeObecnosci() const = 0;
    virtual ~IEksportowalny() {}
};

class IEksporter {
public:
    virtual void wykonajEksport(const IEksportowalny* obj, string nazwaPliku) const = 0;
    virtual ~IEksporter() {}
};

class EksporterTxt : public IEksporter {
public:
    void wykonajEksport(const IEksportowalny* obj, string nazwaPliku) const override {
        ofstream plik(nazwaPliku, ios::app);
        if (!plik) {
            cout << "Uwaga: problem z wygenerowaniem pliku TXT.\n";
            return;
        }

        map<string, string> dane = obj->eksportuj();
        map<string, string>::const_iterator it;

        plik << "[" << dane.at("Typ") << "]\n";
        for (it = dane.begin(); it != dane.end(); ++it) {
            if (it->first != "Typ") {
                plik << it->first << ": " << it->second << "\n";
            }
        }
        plik << "------------------------\n";
        plik.close();
    }
};

class EksporterCsv : public IEksporter {
public:
    void wykonajEksport(const IEksportowalny* obj, string nazwaPliku) const override {
        ofstream plik(nazwaPliku, ios::app);
        if (!plik) {
            cout << "Uwaga: zapis do formatu CSV nie powiodl sie.\n";
            return;
        }

        map<string, string> dane = obj->eksportuj();
        map<string, string>::const_iterator it;

        bool pierwszy = true;
        for (it = dane.begin(); it != dane.end(); ++it) {
            if (!pierwszy) plik << ",";
            plik << it->second;
            pierwszy = false;
        }
        plik << "\n";
        plik.close();
    }
};

class EksporterListaObecnosciTxt : public IEksporter {
public:
    void wykonajEksport(const IEksportowalny* obj, string nazwaPliku) const override {
        ofstream plik(nazwaPliku, ios::app);
        if (!plik) {
            cout << "Uwaga: niemozliwy eksport frekwencji do pliku tekstowego.\n";
            return;
        }

        map<string, string> dane = obj->eksportuj();
        plik << "[Lista obecnosci: " << dane.at("Imie") << " " << dane.at("Nazwisko") << "]\n";

        vector<map<string, string>> listy = obj->eksportujListeObecnosci();
        if (listy.empty()) {
            plik << "  Brak list obecnosci.\n";
        } else {
            for (const auto& wpis : listy) {
                map<string, string>::const_iterator it;
                for (it = wpis.begin(); it != wpis.end(); ++it) {
                    plik << it->first << ": " << it->second << "\n";
                }
                plik << "\n";
            }
        }
        plik << "------------------------\n";
        plik.close();
    }
};

class EksporterListaObecnosciCsv : public IEksporter {
public:
    void wykonajEksport(const IEksportowalny* obj, string nazwaPliku) const override {
        ofstream plik(nazwaPliku, ios::app);
        if (!plik) {
            cout << "Uwaga: awaria zapisu frekwencji jako arkusz CSV.\n";
            return;
        }

        map<string, string> dane = obj->eksportuj();
        string pelneNazwisko = dane.at("Imie") + " " + dane.at("Nazwisko");

        vector<map<string, string>> listy = obj->eksportujListeObecnosci();
        if (listy.empty()) {
            plik << pelneNazwisko << ",brak list\n";
        } else {
            for (const auto& wpis : listy) {
                plik << pelneNazwisko;
                map<string, string>::const_iterator it;
                for (it = wpis.begin(); it != wpis.end(); ++it) {
                    plik << "," << it->second;
                }
                plik << "\n";
            }
        }
        plik.close();
    }
};

class Drukarka {
public:
    static void drukuj(const Przedstawialny& obj) {
        cout << obj.przedstawSie() << endl;
    }
};

class Osoba : public Przedstawialny, public IEksportowalny {
protected:
    int indeks;
    string imie;
    string nazwisko;
    string data_urodzenia;
    float wzrost;
    vector<WpisObecnosci> listy;

    string formatujListy() const {
        string wynik;
        if (listy.empty()) {
            wynik += "  Brak przypisanych list obecnosci.\n";
        } else {
            for (const auto& l : listy) {
                wynik += "  Lista [" + l.nazwa_listy + "]: ";
                wynik += (l.czy_obecny ? "Obecny" : "Nieobecny");
                wynik += "\n";
            }
        }
        return wynik;
    }

public:
    Osoba(int startowy_indeks = 0, string startowe_imie = "", string startowe_nazwisko = "", string data_ur = "Brak", float wzr = 0.0f) {
        indeks = startowy_indeks;
        imie = startowe_imie;
        nazwisko = startowe_nazwisko;
        data_urodzenia = data_ur;
        wzrost = wzr;
    }
    virtual ~Osoba() {}

    virtual void ustaw() {
        cout << "Indeks: "; cin >> indeks;
        cout << "Imie: "; cin >> imie;
        cout << "Nazwisko: "; cin >> nazwisko;
        cout << "Data urodzenia: "; cin >> data_urodzenia;
        cout << "Wzrost: "; cin >> wzrost;
    }

    virtual void edytuj() {
        cout << "Nowy indeks: "; cin >> indeks;
        cout << "Nowe imie: "; cin >> imie;
        cout << "Nowe nazwisko: "; cin >> nazwisko;
        cout << "Nowa data urodzenia: "; cin >> data_urodzenia;
        cout << "Nowy wzrost: "; cin >> wzrost;
    }

    void ustaw_indeks(int wartosc) { indeks = wartosc; }
    void ustaw_imie(string wartosc) { imie = wartosc; }
    void ustaw_nazwisko(string wartosc) { nazwisko = wartosc; }

    int pobierz_indeks() { return indeks; }
    string pobierz_imie() { return imie; }
    string pobierz_nazwisko() { return nazwisko; }

    void dodaj_do_listy(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return;
        }
        listy.push_back({nazwa_listy, false});
    }

    void ustaw_obecnosc(string nazwa_listy, bool obecnosc) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) {
                l.czy_obecny = obecnosc;
                return;
            }
        }
    }

    bool czy_jest_na_liscie(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return true;
        }
        return false;
    }

    bool pobierz_obecnosc(string nazwa_listy) {
        for (auto& l : listy) {
            if (l.nazwa_listy == nazwa_listy) return l.czy_obecny;
        }
        return false;
    }

    string przedstawSie() const override {
        string s = "[" + getTyp() + "] " + to_string(indeks) + " - " + imie + " " + nazwisko + "\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }

    virtual void wyswietl_info() { 
        Drukarka::drukuj(*this);
    }

    virtual string getTyp() const { return "OSOBA"; }

    map<string, string> eksportuj() const override {
        string listyStr;
        for (const auto& l : listy) {
            listyStr += l.nazwa_listy + "=" + (l.czy_obecny ? "Obecny" : "Nieobecny") + " ";
        }
        string przygotowaneListy = listyStr.empty() ? "brak" : listyStr.substr(0, listyStr.length() - 1);

        return {
            {"Typ", getTyp()},
            {"Indeks", to_string(indeks)},
            {"Imie", imie},
            {"Nazwisko", nazwisko},
            {"DataUrodzenia", data_urodzenia},
            {"Wzrost", to_string(wzrost)},
            {"Listy", przygotowaneListy}
        };
    }

    vector<map<string, string>> eksportujListeObecnosci() const override {
        vector<map<string, string>> wynik;
        for (const auto& l : listy) {
            map<string, string> wpis;
            wpis["Nazwa"] = l.nazwa_listy;
            wpis["Status"] = l.czy_obecny ? "Obecny" : "Nieobecny";
            wynik.push_back(wpis);
        }
        return wynik;
    }
};

class Student : public Osoba {
protected:
    string kierunek;
    int semestr;
public:
    Student(int inx = 0, string im = "", string naz = "", string kier = "", int sem = 0, string data_ur = "Brak", float wzr = 0.0f) 
        : Osoba(inx, im, naz, data_ur, wzr), kierunek(kier), semestr(sem) {}

    void ustaw() override {
        Osoba::ustaw();
        cout << "Kierunek: "; cin >> kierunek;
        cout << "Semestr: "; cin >> semestr;
    }

    void edytuj() override {
        Osoba::edytuj();
        cout << "Nowy kierunek: "; cin >> kierunek;
        cout << "Nowy semestr: "; cin >> semestr;
    }

    void setKierunek(string nowy_kierunek) { kierunek = nowy_kierunek; }
    void setSemestr(int nowy_sem) { semestr = nowy_sem; }

    string getTyp() const override { return "STUDENT"; }

    string przedstawSie() const override {
        string s = "[" + getTyp() + "] " + to_string(indeks) + " - " + imie + " " + nazwisko + " (" + kierunek + ", semestr: " + to_string(semestr) + ")\n";
        s += "Data urodzenia: " + data_urodzenia + " | Wzrost: " + to_string(wzrost) + " cm\n";
        s += formatujListy();
        return s;
    }

    map<string, string> eksportuj() const override {
        map<string, string> dane = Osoba::eksportuj();
        dane["Kierunek"] = kierunek;
        dane["Semestr"] = to_string(semestr);
        return dane;
    }
};

