#include <iostream>
#include <string>

using namespace std;

const int N = 10;

class Osoba {
private:
    int indeks;
    string imie;
    string nazwisko;
public:
    Osoba(int startowy_indeks = 0, string startowe_imie = "", string startowe_nazwisko = "") {
        indeks = startowy_indeks;
        imie = startowe_imie;
        nazwisko = startowe_nazwisko;
    }
    void ustaw_indeks(int wartosc) { indeks = wartosc; }
    void ustaw_imie(string wartosc) { imie = wartosc; }
    void ustaw_nazwisko(string wartosc) { nazwisko = wartosc; }
    int pobierz_indeks() { return indeks; }
    string pobierz_imie() { return imie; }
    string pobierz_nazwisko() { return nazwisko; }
};

class listaObecnosci {
private:
    Osoba baza_osob[N];
    Osoba *wsk_lista1[N];
    bool obecnosc_lista1[N];
    Osoba *wsk_lista2[N];
    bool obecnosc_lista2[N];

    int szukaj_osoby(string szukane_nazwisko) {
        for (int i = 0; i < N; i++) {
            if (baza_osob[i].pobierz_nazwisko() == szukane_nazwisko) {
                return i;
            }
        }
        return -1;
    }

    int szukaj_pustego_wskaznika(Osoba **lista_wsk) {
        for (int i = 0; i < N; i++) {
            if (lista_wsk[i] == NULL) {
                return i;
            }
        }
        return -1;
    }

    int szukaj_pustego_miejsca() {
        for (int i = 0; i < N; i++) {
            if (baza_osob[i].pobierz_nazwisko() == "") {
                return i;
            }
        }
        return -1;
    }

    void pokaz_wybrana_liste(Osoba **wybrana_lista, bool *tab_obecnosc) {
        for (int i = 0; i < N; i++) {
            if (wybrana_lista[i] != NULL && wybrana_lista[i]->pobierz_nazwisko() != "") {
                cout << wybrana_lista[i]->pobierz_indeks() << " - " 
                     << wybrana_lista[i]->pobierz_imie() << " " 
                     << wybrana_lista[i]->pobierz_nazwisko() 
                     << " obecnosc: " << tab_obecnosc[i] << endl;
            }
        }
    }

public:
    listaObecnosci() {
        for (int i = 0; i < N; i++) {
            wsk_lista1[i] = NULL;
            wsk_lista2[i] = NULL;
            obecnosc_lista1[i] = false;
            obecnosc_lista2[i] = false;
        }
    }

    void dodaj_osobe(Osoba nowa_osoba) {
        int pozycja = szukaj_pustego_miejsca();
        if (pozycja != -1) {
            baza_osob[pozycja] = nowa_osoba;
        } else {
            cout << "Nie ma juz miejsca na nowa osobe!" << endl;
        }
    }

    void edytuj_osobe(string tekst_do_edycji) {
        int i = szukaj_osoby(tekst_do_edycji);
        if (i != -1) {
            int nowy_indeks;
            string nowe_imie, nowe_nazwisko;
            cout << "Podaj nowy indeks: "; cin >> nowy_indeks;
            cout << "Podaj nowe imie: "; cin >> nowe_imie;
            cout << "Podaj nowe nazwisko: "; cin >> nowe_nazwisko;
            baza_osob[i].ustaw_indeks(nowy_indeks);
            baza_osob[i].ustaw_imie(nowe_imie);
            baza_osob[i].ustaw_nazwisko(nowe_nazwisko);
        } else {
            cout << "Nie znaleziono takiego nazwiska!" << endl;
        }
    }

    void usun_osobe(string tekst_do_edycji) {
        int pozycja = szukaj_osoby(tekst_do_edycji);
        if (pozycja != -1) {
            for (int i = pozycja; i < N - 1; i++) {
                baza_osob[i].ustaw_indeks(baza_osob[i + 1].pobierz_indeks());
                baza_osob[i].ustaw_imie(baza_osob[i + 1].pobierz_imie());
                baza_osob[i].ustaw_nazwisko(baza_osob[i + 1].pobierz_nazwisko());
            }
            baza_osob[N - 1] = Osoba();
            cout << "Osoba usunieta." << endl;
        } else {
            cout << "Nie ma kogo usunac, brak nazwiska w bazie." << endl;
        }
    }

    void dodaj_do_listy(int numer_listy, string nazwisko_osoby) {
        int index_baza = szukaj_osoby(nazwisko_osoby);
        if (index_baza != -1) {
            Osoba **wybrana_lista = (numer_listy == 1) ? wsk_lista1 : wsk_lista2;
            bool *tab_obecnosc = (numer_listy == 1) ? obecnosc_lista1 : obecnosc_lista2;
            
            int index_lista = szukaj_pustego_wskaznika(wybrana_lista);
            if (index_lista != -1) {
                wybrana_lista[index_lista] = &baza_osob[index_baza];
                tab_obecnosc[index_lista] = false;
            } else {
                cout << "Brak miejsca na tej liscie." << endl;
            }
        } else {
            cout << "Nie znaleziono osoby w bazie." << endl;
        }
    }

    void ustaw_obecnosc(int numer_listy, string nazwisko_osoby, bool czy_obecny) {
        Osoba **wybrana_lista = (numer_listy == 1) ? wsk_lista1 : wsk_lista2;
        bool *tab_obecnosc = (numer_listy == 1) ? obecnosc_lista1 : obecnosc_lista2;

        for (int i = 0; i < N; i++) {
            if (wybrana_lista[i] != NULL && wybrana_lista[i]->pobierz_nazwisko() == nazwisko_osoby) {
                tab_obecnosc[i] = czy_obecny;
                return;
            }
        }
        cout << "Osoby nie ma na tej liscie." << endl;
    }

    void wyswietl(int numer_listy) {
        if (numer_listy == 1) {
            cout << "\nOsoby na liscie 1:" << endl;
            pokaz_wybrana_liste(wsk_lista1, obecnosc_lista1);
        } else if (numer_listy == 2) {
            cout << "\nOsoby na liscie 2:" << endl;
            pokaz_wybrana_liste(wsk_lista2, obecnosc_lista2);
        } else {
            cout << "Zly numer listy!" << endl;
        }
    }
};

int main() {
    listaObecnosci system_obecnosci;
    bool czy_menu_aktywne = true;
    int wybor_uzytkownika;
    string imie_osoby, nazwisko_osoby, tekst_do_edycji;
    int nr_indeksu, numer_wybranej_listy;
    bool czy_obecny;

    cout << "Program do obslugi list studentow" << endl;

    while (czy_menu_aktywne) {
        cout << "\n=============================" << endl;
        cout << "Wybierz opcje:" << endl;
        cout << "1. Utworz osobe" << endl;
        cout << "2. Dodaj osobe do listy" << endl;
        cout << "3. Ustaw obecnosc osoby na liscie" << endl;
        cout << "4. Usun osobe z bazy" << endl;
        cout << "5. Zmien dane osoby" << endl;
        cout << "6. Wyswietl liste" << endl;
        cout << "7. Wyjdz" << endl;
        cout << "Wybor: ";
        cin >> wybor_uzytkownika;

        system("clear");

        if (wybor_uzytkownika == 1) {
            cout << "Indeks: "; cin >> nr_indeksu;
            cout << "Imie: "; cin >> imie_osoby;
            cout << "Nazwisko: "; cin >> nazwisko_osoby;
            Osoba wpis(nr_indeksu, imie_osoby, nazwisko_osoby);
            system_obecnosci.dodaj_osobe(wpis);
        } 
        else if (wybor_uzytkownika == 2) {
            cout << "Podaj nazwisko: "; cin >> nazwisko_osoby;
            cout << "Do jakiej listy dodac? 1 albo 2: "; cin >> numer_wybranej_listy;
            system_obecnosci.dodaj_do_listy(numer_wybranej_listy, nazwisko_osoby);
        } 
        else if (wybor_uzytkownika == 3) {
            cout << "Podaj nazwisko: "; cin >> nazwisko_osoby;
            cout << "Ustaw obecnosc (1 - tak, 0 - nie): "; cin >> czy_obecny;
            cout << "Na jakiej liscie? 1 albo 2: "; cin >> numer_wybranej_listy;
            system_obecnosci.ustaw_obecnosc(numer_wybranej_listy, nazwisko_osoby, czy_obecny);
        } 
        else if (wybor_uzytkownika == 4) {
            cout << "Podaj nazwisko osoby do usuniecia: ";
            cin >> tekst_do_edycji;
            system_obecnosci.usun_osobe(tekst_do_edycji);
        } 
        else if (wybor_uzytkownika == 5) {
            cout << "Podaj nazwisko osoby do edycji: ";
            cin >> tekst_do_edycji;
            system_obecnosci.edytuj_osobe(tekst_do_edycji);
        } 
        else if (wybor_uzytkownika == 6) {
            cout << "Ktora liste chcesz wyswietlic (1 albo 2): "; 
            cin >> numer_wybranej_listy;
            system_obecnosci.wyswietl(numer_wybranej_listy);
        } 
        else if (wybor_uzytkownika == 7) {
            cout << "Koniec programu." << endl;
            czy_menu_aktywne = false;
        }
        else {
            cout << "Brak takiej opcji." << endl;
        }
    }
    return 0;
}
